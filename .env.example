# ─────────────────────────────────────────
# 업비트 API 인증 (https://upbit.com/mypage/open_api_management)
# ─────────────────────────────────────────
UPBIT_ACCESS_KEY=your_access_key_here
UPBIT_SECRET_KEY=your_secret_key_here

# ─────────────────────────────────────────
# LLM 설정 (OpenAI API)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1

# ─────────────────────────────────────────
# 텔레그램 봇 (https://t.me/BotFather)
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:your_bot_token
TELEGRAM_CHAT_ID=your_chat_id  # /start 후 https://api.telegram.org/bot{TOKEN}/getUpdates 로 확인

# ─────────────────────────────────────────
# 매매 대상 코인 설정
# ─────────────────────────────────────────
TARGET_MARKETS=KRW-BTC,KRW-ETH,KRW-SOL
# 0이면 TARGET_MARKETS 사용. N이면 24h 거래대금 상위 N개 자동 선택 (1시간마다 갱신).
# 설정 시 TARGET_MARKETS는 무시됨. 단, 현재 보유 중인 코인은 항상 거래 대상에 포함됨.
TARGET_MARKETS_TOP_N=0
DEFAULT_STRATEGY=momentum
TRADE_INTERVAL_SECONDS=60
# 진입 탐색용 캔들 단위(분): 0=일봉, 1, 3, 5, 10, 15, 30, 60, 240
CANDLE_UNIT_MINUTES=0
# 포지션 보유 중 캔들 단위(분): 0=일봉, 1, 3, 5, 10, 15, 30, 60, 240
CANDLE_UNIT_POSITION_MINUTES=60
# 가져올 캔들 수 (최대 200). 예) 일봉 200개=200일치, 60분봉 200개=약 8일치
CANDLE_COUNT=200

# ─────────────────────────────────────────
# 리스크 관리
# ─────────────────────────────────────────
# 포트폴리오 최대 낙폭 % (초과 시 매크로 킬스위치 발동)
MACRO_MAX_DRAWDOWN_PCT=15.0
# 개별 포지션 손절 % (초과 시 마이크로 킬스위치 발동)
MICRO_STOP_LOSS_PCT=3.0
# 단일 코인 최대 투자 비중 %
MAX_POSITION_PCT=30.0

# ─────────────────────────────────────────
# 피라미딩 전략 설정 (pyramid_breakout / pyramid_breakout_ls)
# ─────────────────────────────────────────
# 매수 1회당 고정 투입 금액(원). 첫 진입과 피라미딩 추가매수 모두 동일하게 적용.
PYRAMID_UNIT_AMOUNT=100000
# 저점 대비 진입 상승률 (%)
PYRAMID_ENTRY_PCT=10.0
# 첫 진입가 대비 추가매수 간격 (%)
PYRAMID_ADD_PCT=10.0
# 첫 진입가 대비 손절 하락률 (%)
PYRAMID_STOP_PCT=10.0
# 최고가 대비 트레일링 스탑 하락률 (%)
PYRAMID_TRAIL_PCT=10.0
# 원화 잔고가 이 금액(원) 이하일 때 텔레그램 경고 발송 (5분마다 체크, 중복 알림 없음)
MIN_KRW_ALERT=10000

# ─────────────────────────────────────────
# 백테스트 설정
# ─────────────────────────────────────────
DEFAULT_FEE_BPS=5       # 0.05% 업비트 수수료
DEFAULT_SLIPPAGE_BPS=3  # 슬리피지 추정치

# ─────────────────────────────────────────
# 데이터베이스
# ─────────────────────────────────────────
DB_PATH=data/db/trading.db

# ─────────────────────────────────────────
# 개발/테스트 모드
# ─────────────────────────────────────────
# paper: 모의매매 (실제 주문 없음), live: 실거래
TRADING_MODE=paper
LOG_LEVEL=INFO
